{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "includeFiles": "public/**" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "app.py" },
    { "src": "/chat",        "dest": "app.py" },
    { "src": "/stream",      "dest": "app.py" },
    { "src": "/",            "dest": "/public/index.html" },
    { "src": "/(.*\\.(?:js|css|png|svg|ico|woff2?|jpg|jpeg|webp))", "dest": "/public/$1" },
    { "src": "/(.*)",        "dest": "/public/index.html" }
  ]
}
